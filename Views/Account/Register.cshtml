@model RegisterModel
@{
    ViewBag.Title = "Student Register";
}

<style>
    body {
        background-image: url('/images/RegisterSSS1.jpg');
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
    }

    .registration-card {
        background-color: rgba(255, 255, 255, 0.95);
        padding: 30px;
        border-radius: 10px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        margin-top: 50px;
        margin-bottom: 50px;
    }

    .guide-box {
        background-color: #e7f3ff;
        border-left: 5px solid #0d6efd;
        padding: 20px;
        border-radius: 5px;
        height: fit-content;
        margin-top: 50px;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .input-group-text {
        cursor: pointer;
    }
</style>

<div class="container">
    <div class="row">
        <div class="col-lg-7">
            <div class="registration-card">
                <h2 class="fw-bold text-primary mb-3">User Registration</h2>
                <p class="text-muted">
                    You are not yet registered for using Ufs Connect Book.
                    Please enter your personal details below.
                </p>

                <div class="text-danger" asp-validation-summary="All"></div>

                <form asp-action="Register" asp-controller="Account" method="post">
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label asp-for="Name" class="fw-bold"></label>
                            <input asp-for="Name" class="form-control" placeholder="Enter Name" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label asp-for="Surname" class="fw-bold"></label>
                            <input asp-for="Surname" class="form-control" placeholder="Enter Surname" />
                            <span asp-validation-for="Surname" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="EmailAddress" class="fw-bold"></label>
                        <input asp-for="EmailAddress" class="form-control" placeholder="example@ufs4life.ac.za" />
                        <span asp-validation-for="EmailAddress" class="text-danger small"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Identification" class="fw-bold">Identification (10 Digits)</label>
                        <input asp-for="Identification" class="form-control" placeholder="e.g. 1234567890" />
                        <span asp-validation-for="Identification" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label asp-for="Password" class="fw-bold"></label>
                            <div class="input-group">
                                <input asp-for="Password" class="form-control" id="password-input" type="password" />
                                <span class="input-group-text" onclick="togglePassword('password-input', 'toggle-icon-1')">
                                    <i id="toggle-icon-1" class="fa fa-eye"></i>
                                </span>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 form-group">
                            <label asp-for="ConfirmPassword" class="fw-bold"></label>
                            <div class="input-group">
                                <input asp-for="ConfirmPassword" class="form-control" id="confirm-password-input" type="password" />
                                <span class="input-group-text" onclick="togglePassword('confirm-password-input', 'toggle-icon-2')">
                                    <i id="toggle-icon-2" class="fa fa-eye"></i>
                                </span>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-grid gap-2 mt-4">
                        <button class="btn btn-primary btn-lg" type="submit">Create Account</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-5 d-none d-lg-block">
            <div class="guide-box shadow-sm">
                <h5 class="fw-bold text-primary"><i class="fas fa-info-circle me-2"></i>Registration Guides</h5>
                <hr />
                <ul class="list-unstyled">
                    <li class="mb-3">
                        <i class="fas fa-id-card text-primary me-2"></i>
                        <strong>Identification:</strong> Must be exactly <strong>10 digits</strong> long.
                    </li>
                    <li class="mb-3">
                        <i class="fas fa-lock text-primary me-2"></i>
                        <strong>Password:</strong> Must be at least <strong>6 characters</strong> long.
                    </li>
                    <li class="mb-3">
                        <i class="fas fa-envelope text-primary me-2"></i>
                        <strong>Email:</strong> Use your official university email address.
                    </li>
                    <li>
                        <i class="fas fa-check-circle text-success me-2"></i>
                        Ensure all information matches your campus records.
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePassword(inputId, iconId) {
        var input = document.getElementById(inputId);
        var icon = document.getElementById(iconId);
        if (input.type === "password") {
            input.type = "text";
            icon.classList.remove("fa-eye");
            icon.classList.add("fa-eye-slash");
        } else {
            input.type = "password";
            icon.classList.remove("fa-eye-slash");
            icon.classList.add("fa-eye");
        }
    }
</script>