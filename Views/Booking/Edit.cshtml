@model Booking
@{
    ViewData["Title"] = "Edit Booking";
}

<style>
    body {
        background-image: url('/images/Booking.png');
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .edit-card {
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 15px;
        padding: 40px;
        margin: 50px auto;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        max-width: 600px;
    }

    .edit-header {
        border-bottom: 2px solid #f0f0f0;
        margin-bottom: 25px;
        padding-bottom: 10px;
    }

    h4 {
        color: #333;
        font-weight: 700;
        margin-bottom: 5px;
    }

    .facility-badge {
        background-color: #e9ecef;
        color: #495057;
        padding: 5px 15px;
        border-radius: 20px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .form-label {
        font-weight: 600;
        color: #555;
        margin-top: 15px;
    }

    .form-control {
        border-radius: 8px;
        padding: 12px;
        border: 1px solid #ced4da;
    }

    .form-control:focus {
        box-shadow: 0 0 0 0.25rem rgba(76, 175, 80, 0.25);
        border-color: #4CAF50;
    }

    .btn-save {
        background-color: #4CAF50;
        color: white;
        border: none;
        padding: 12px 30px;
        border-radius: 50px;
        font-weight: 600;
        transition: all 0.3s;
        margin-top: 20px;
    }

    .btn-save:hover {
        background-color: #45a049;
        transform: translateY(-2px);
    }

    .btn-back {
        color: #6c757d;
        text-decoration: none;
        margin-left: 15px;
        font-weight: 500;
    }

    .btn-back:hover {
        color: #333;
    }
</style>

<div class="edit-card">
    <div class="edit-header text-center">
        <h4>Edit Booking</h4>
        <span class="facility-badge"><i class="fas fa-building me-1"></i> @Model.Facility?.Name</span>
    </div>

    <form asp-action="Edit" method="post">
        <div class="text-danger mb-3" asp-validation-summary="All"></div>

        @* Hidden Fields to preserve data *@
        <input type="hidden" asp-for="BookingDate" />
        <input type="hidden" asp-for="Duration" />
        <input type="hidden" asp-for="userEmail" />
        <input type="hidden" asp-for="Status" />
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Facility</label>
            <select asp-items="@ViewBag.FacilityId" asp-for="FacilityId" class="form-select form-control">
                <option disabled selected>--- Select Facility ---</option>
            </select>
            <span asp-validation-for="FacilityId" class="text-danger small"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="StartTime" class="form-label">Start Time</label>
                @* Using type="datetime-local" for better browser compatibility *@
                <input asp-for="StartTime" type="datetime-local" class="form-control" 
                       value="@Model.StartTime.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="StartTime" class="text-danger small"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="EndTime" class="form-label">End Time</label>
                <input asp-for="EndTime" type="datetime-local" class="form-control" 
                       value="@Model.EndTime.ToString("yyyy-MM-ddTHH:mm")" />
                <span asp-validation-for="EndTime" class="text-danger small"></span>
            </div>
        </div>

        <div class="text-center mt-4">
            <button type="submit" class="btn btn-save shadow-sm">
                <i class="fas fa-save me-2"></i>Save Changes
            </button>
            <a asp-action="Index" class="btn-back">
                <i class="fas fa-arrow-left me-1"></i>Back To List
            </a>
        </div>
    </form>
</div>
}
