@model IEnumerable<Booking>
@{
    ViewData["Title"] = "My Bookings";
}

<style>
    body {
        background-image: url('/images/Booking.png');
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .bookings-card {
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 12px;
        padding: 30px;
        max-width: 900px;
        margin: 50px auto;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
    }

    h4 {
        text-align: center;
        margin-bottom: 25px;
        color: #333;
    }

    .btn-primary {
        background-color: #4CAF50;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: bold;
        margin-bottom: 15px;
    }

    a.btn-link {
        color: #4CAF50;
        font-weight: 600;
        text-decoration: none;
    }

    a.btn-link:hover {
        text-decoration: underline;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 15px;
    }

    table th, table td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #ddd;
    }

    table th {
        background-color: #f5f5f5;
        font-weight: 600;
    }

    .action-buttons a, .action-buttons button {
        margin-right: 8px;
        border: none;
        background: none;
        cursor: pointer;
        font-size: 16px;
    }

    .text-primary { color: #007bff; }
    .text-info { color: #17a2b8; }
    .text-danger { color: #dc3545; }

    .feedback-button {
        margin-top: 20px;
        background-color: #FFC107;
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 8px 16px;
        font-weight: bold;
        cursor: pointer;
    }

    .feedback-button:hover {
        background-color: #ffb300;
    }

    @media (max-width: 768px) {
        table th, table td {
            padding: 8px;
            font-size: 14px;
        }
    }
</style>

<div class="bookings-card">
    <h4>My Bookings</h4>
    <a asp-action="Create" asp-controller="Booking" class="btn btn-primary">Book New</a>

    <table>
        <thead>
            <tr>
                <th>Start Time</th>
                <th>End Time</th>
                <th>Facility</th>
                <th>Date</th>
                <th>Status</th>
                <th colspan="3">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var booking in Model)
            {
                <tr>
                    <td>@booking.StartTime.ToShortTimeString()</td>
                    <td>@booking.EndTime.ToShortTimeString()</td>
                    <td>@booking.Facility?.Name</td>
                    <td>@booking.BookingDate?.ToString("dd MMM yyyy")</td>
                    <td>@booking.Status</td>
                    <td class="action-buttons">
                        <a asp-action="Details" asp-route-bookingID="@booking.Id" class="text-primary fa fa-eye"></a>
                        @if (booking.Status == "Pending")
                        {
                            <a asp-action="Edit" asp-route-bookingID="@booking.Id" class="text-info fa fa-edit"></a>
                            <form asp-controller="Booking" asp-action="ConfirmCancel" asp-route-bookingID="@booking.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to cancel this booking?');">
                                <button type="submit" class="text-danger fa fa-delete-left"></button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <form asp-controller="Booking" asp-action="FeedBack" method="get" style="text-align:center;">
        <button type="submit" class="feedback-button">Feedback</button>
    </form>
</div>
