@model IEnumerable<Booking>

@{
    ViewData["Title"] = "Bookings";
}

<style>
    body {
        background-image: url('/images/Booking.png');
        background-size: cover;
        background-repeat: no-repeat;
        background-attachment: fixed;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .bookings-card {
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 12px;
        padding: 30px;
        margin: 40px auto;
        box-shadow: 0 4px 20px rgba(0,0,0,0.2);
        max-width: 1000px;
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
        border-bottom: 2px solid #f0f0f0;
        padding-bottom: 15px;
    }

    h4 {
        color: #333;
        font-weight: 700;
        margin: 0;
    }

    .btn-group-nav {
        display: flex;
        gap: 10px;
    }

    .table {
        vertical-align: middle;
    }

    .table thead th {
        background-color: #f8f9fa;
        color: #555;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        border: none;
    }

    .status-badge {
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .status-pending { background-color: #fff3cd; color: #856404; }
    .status-confirmed { background-color: #d4edda; color: #155724; }
    .status-default { background-color: #e2e3e5; color: #383d41; }

    .action-btn {
        background: none;
        border: none;
        padding: 5px;
        transition: transform 0.2s;
        text-decoration: none;
        display: inline-block;
    }

    .action-btn:hover {
        transform: scale(1.2);
    }

    .btn-primary-modern {
        background-color: #4CAF50;
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-primary-modern:hover {
        background-color: #45a049;
        color: white;
    }

    .btn-feedback {
        background-color: #6c757d;
        color: white;
        border: none;
        padding: 8px 20px;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-feedback:hover {
        background-color: #5a6268;
        color: white;
    }
</style>

<div class="bookings-card">
    <div class="header-section">
        <h4>My Bookings</h4>
        <div class="btn-group-nav">
            <a asp-action="Create" asp-controller="Booking" class="btn btn-primary-modern">
                <i class="fas fa-plus me-1"></i> Book New
            </a>
            <a asp-action="FeedBack" asp-controller="Booking" class="btn btn-feedback">
                <i class="fas fa-comment-alt me-1"></i> Feedback
            </a>
        </div>
    </div>

    @if (ViewBag.Message != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @ViewBag.Message
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>Start Time</th>
                    <th>End Time</th>
                    <th>Facility</th>
                    <th>Date</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var booking in Model)
                {
                    <tr>
                        @* Added .ToLocalTime() to handle the UTC conversion from your controller *@
                        <td>@booking.StartTime.ToLocalTime().ToShortTimeString()</td>
                        <td>@booking.EndTime.ToLocalTime().ToShortTimeString()</td>
                        <td class="fw-bold">@booking.Facility?.Name</td>
                        <td>@(booking.BookingDate.HasValue ? booking.BookingDate.Value.ToLocalTime().ToShortDateString() : "N/A")</td>
                        <td>
                            <span class="status-badge @(booking.Status == "Pending" ? "status-pending" : (booking.Status == "Approved" ? "status-confirmed" : "status-default"))">
                                @booking.Status
                            </span>
                        </td>
                        <td class="text-end">
                            <div class="d-flex justify-content-end align-items-center gap-2">
                                <a asp-action="Details" asp-route-bookingID="@booking.Id" class="text-primary action-btn" title="View Details">
                                    <i class="fas fa-eye"></i>
                                </a>

                                @if (booking.Status == "Pending")
                                {
                                    <a asp-action="Edit" asp-route-bookingID="@booking.Id" class="text-info action-btn" title="Edit Booking">
                                        <i class="fas fa-edit"></i>
                                    </a>

                                    <form asp-controller="Booking" asp-action="ConfirmCancel" asp-route-bookingID="@booking.Id" method="post" onsubmit="return confirm('Are you sure you want to cancel this booking?');" class="d-inline">
                                        <button type="submit" class="text-danger action-btn" title="Cancel Booking">
                                            <i class="fas fa-trash-alt"></i>
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
