<!DOCTYPE html>
<html lang="en">

@{
    ViewBag.Title = "Home page";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    body {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        background-attachment: fixed;
        margin: 0;
        padding: 0;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        color: #2d3436;
    }

    .hero-section {
        padding: 80px 0 60px;
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        margin-bottom: 50px;
    }

    .main-title {
        font-weight: 800;
        letter-spacing: -1px;
        background: linear-gradient(90deg, #0d6efd, #6610f2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 15px;
    }

    .engineer-text {
        font-size: 1.2rem;
        color: #6c757d;
        min-height: 1.5em;
    }

    .facility-card {
        background: #ffffff;
        border: 1px solid rgba(0,0,0,0.05);
        border-radius: 16px;
        padding: 24px;
        height: 100%;
        box-shadow: 0 10px 30px rgba(0,0,0,0.02);
        transition: box-shadow 0.3s ease;
    }

    .facility-image {
        border-radius: 12px;
        width: 100%;
        height: 180px;
        object-fit: cover;
        margin-bottom: 20px;
        filter: grayscale(20%);
    }

    .info-badge {
        display: inline-block;
        padding: 4px 12px;
        background: #e7f3ff;
        color: #0d6efd;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        margin-bottom: 10px;
    }

    .step-guide {
        background: #0d6efd;
        color: white;
        padding: 40px 0;
        margin-top: 60px;
        border-radius: 20px 20px 0 0;
    }

    .step-icon {
        font-size: 2rem;
        margin-bottom: 15px;
        opacity: 0.9;
    }
</style>

<div class="hero-section text-center">
    <div class="container">
        <h1 class="display-3 main-title">ConectBook Facility Portal</h1>
        <div id="welcomeText" class="engineer-text fw-medium"></div>
        <div class="mt-4">
            <p class="text-muted mx-auto" style="max-width: 600px;">
                Streamlining resource management. To begin your reservation, 
                please register and access the <strong>Menu</strong> above.
            </p>
        </div>
    </div>
</div>

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h2 class="fw-bold m-0">Available Resources</h2>
        <span class="text-muted small">Information Desk</span>
    </div>

    <div class="row g-4">
        <div class="col-lg-3 col-md-6">
            <div class="facility-card">
                <span class="info-badge">Secure Access</span>
                <img src="/images/ParkingSlots.jpg" class="facility-image" />
                <h5 class="fw-bold">Parking Spaces</h5>
                <p class="text-muted small">Reserved student and staff parking bays with 24/7 security monitoring.</p>
                <div class="text-warning small">
                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i><i class="far fa-star"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="facility-card">
                <span class="info-badge">In-House</span>
                <img src="/images/LaundryR.jpg" class="facility-image" />
                <h5 class="fw-bold">Laundry Room</h5>
                <p class="text-muted small">Avoid the queue. Pre-book your machine and receive status notifications.</p>
                <div class="text-warning small">
                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i><i class="far fa-star"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="facility-card">
                <span class="info-badge">Quiet Zone</span>
                <img src="/images/LibraryRoom.jpg" class="facility-image" />
                <h5 class="fw-bold">Library Study</h5>
                <p class="text-muted small">Private and group discussion rooms equipped with smart whiteboards.</p>
                <div class="text-warning small">
                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="far fa-star"></i>
                </div>
            </div>
        </div>

        <div class="col-lg-3 col-md-6">
            <div class="facility-card">
                <span class="info-badge">Wellness</span>
                <img src="/images/Gym.jpg" class="facility-image" />
                <h5 class="fw-bold">Gym Center</h5>
                <p class="text-muted small">Fully equipped fitness center. Check peak hours and book your session.</p>
                <div class="text-warning small">
                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star-half-alt"></i><i class="far fa-star"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="step-guide">
    <div class="container">
        <div class="row text-center">
            <div class="col-md-4">
                <i class="fas fa-user-plus step-icon"></i>
                <h6>1. Register</h6>
                <p class="small opacity-75">Create your profile</p>
            </div>
            <div class="col-md-4">
                <i class="fas fa-calendar-check step-icon"></i>
                <h6>2. Reserve</h6>
                <p class="small opacity-75">Pick a time and facility</p>
            </div>
            <div class="col-md-4">
                <i class="fas fa-credit-card step-icon"></i>
                <h6>3. Secure</h6>
                <p class="small opacity-75">Get approved by the manager</p>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    const welcomeText = document.getElementById("welcomeText");
    const fullText = "Engineered by Lindele Xolani Nyambe";
    let index = 0;

    function typeEffect() {
        if (index < fullText.length) {
            welcomeText.textContent += fullText.charAt(index);
            index++;
            setTimeout(typeEffect, 70);
        }
    }
    
    window.onload = typeEffect;
</script>
